      "updated": 1777287929961,
      "link": null,
      "locked": false,
      "text": "Når vi starter et prosjekt vet vi ikke:\n    - Alle krav\n    - Alle edge cases\n    - Alle avhengigheter",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Når vi starter et prosjekt vet vi ikke:\n    - Alle krav\n    - Alle edge cases\n    - Alle avhengigheter",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ECLOxz_El2PS-40hxyP_7",
      "type": "text",
      "x": 646.6604875951118,
      "y": 1287.226324960907,
      "width": 558.959716796875,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
