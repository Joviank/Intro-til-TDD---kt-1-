    {
      "id": "-6QgK0EeM6BbL8VofIs9t",
      "type": "text",
      "x": 264.8940261195013,
      "y": 883.663868263672,
      "width": 832.0994873046875,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6m",
      "roundness": null,
      "seed": 1044752663,
      "version": 533,
      "versionNonce": 447773335,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777287879635,
      "link": null,
      "locked": false,
      "text": "1. Å identifisere et behov eller et problem i systemet (Observasjon/Observerer behov)\n    Vi trenger å kunne legge sammen to tall\n\n2. Vi lager en test (Hypotese/Skrive test)\n    Calculator.Add(2,2) should equal 4\n\n3. Vi kjører testen (Eksperiment)\n4. Testen passerer eller feiler (Resultat)\n5. Enten implementerer vi kode eller faktorer koden (konklusjon/Endre kode)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Å identifisere et behov eller et problem i systemet (Observasjon/Observerer behov)\n    Vi trenger å kunne legge sammen to tall\n\n2. Vi lager en test (Hypotese/Skrive test)\n    Calculator.Add(2,2) should equal 4\n\n3. Vi kjører testen (Eksperiment)\n4. Testen passerer eller feiler (Resultat)\n5. Enten implementerer vi kode eller faktorer koden (konklusjon/Endre kode)",
      "autoResize": true,
      "lineHeight": 1.25
    },
